DEBUG=false

# Optional API key required by llm-bot itself for incoming requests.
API_KEY=

# OpenRouter uses the OpenAI-compatible API under /api/v1.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openrouter/owl-alpha
LLM_API_MODE=chat_completions
LLM_TIMEOUT=120

LLM_STRIP_REASONING_OUTPUT=true
